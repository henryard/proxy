#!name=DNS 防泄漏与安全
#!desc=防止 DNS 泄漏与 ISP 劫持。使用 DoH 加密请求，强制关闭 IPv6，并劫持传统 53 端口。订阅更新不会覆盖此模块。
#!author=Gemini

[General]
# 1. 强制禁用 IPv6
# 绝大多数 DNS 泄漏是由 IPv6 引起的（因为部分节点或配置不支持代理 IPv6 流量，导致直连）。
ipv6 = false

# 2. 替换默认 DNS 为 DoH (DNS over HTTPS)
# 将传统的明文 DNS 替换为加密 DNS，防止运营商 (ISP) 嗅探和劫持。
# 前两个为阿里和腾讯的 DoH（保证国内直连解析速度），后两个为传统备用。
dns-server = https://dns.alidns.com/dns-query, https://doh.pub/dns-query, 223.5.5.5, 119.29.29.29

# 3. 备用 (Fallback) DNS
# 当主 DNS 无法解析出结果（通常是海外被墙域名）时，使用的备用加密 DNS。
fallback-dns-server = https://dns.google/dns-query, https://cloudflare-dns.com/dns-query, 8.8.8.8, 1.1.1.1

# 4. 强制劫持 DNS (Hijack DNS)
# 很多 App（如 YouTube, Netflix 等）会在代码里硬编码自己的 DNS (如 8.8.8.8:53)，从而绕过系统 DNS 导致泄漏。
# 这里强制拦截这些请求，交由 Shadowrocket 处理。
hijack-dns = 8.8.8.8:53, 8.8.4.4:53
